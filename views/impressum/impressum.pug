extends ../index

block content
    .mb-10
        h1.text-4xl.md--text-5xl.font-bold.text-white.mb-4= t.impressum.title
        .h-1.w-20.bg-green-600.rounded

    .max-w-2xl.space-y-6
        //- § 5 TMG — Site owner
        section
            h2.text-lg.font-bold.text-zinc-300.mb-3= t.impressum.ownerTitle
            .bg-zinc-800.rounded-xl.p-6.border.border-zinc-700.space-y-1
                p.text-zinc-300.font-semibold= t.impressum.name
                p.text-zinc-400= t.impressum.addressLine1
                p.text-zinc-400= t.impressum.addressLine2
                p.text-zinc-400= t.impressum.addressLine3

        //- Contact
        section
            h2.text-lg.font-bold.text-zinc-300.mb-3= t.impressum.contactTitle
            .bg-zinc-800.rounded-xl.p-6.border.border-zinc-700
                p.text-zinc-400
                    | #{t.impressum.emailLabel}:&nbsp;
                    a(href="mailto:" + "fe-wiegleb@t-online.de").text-green-500.hover--text-green-400.transition-colors fe-wiegleb@t-online.de
                    | &nbsp;&nbsp;/&nbsp;&nbsp;
                    a(href="mailto:" + "js-wiegleb@t-online.de").text-green-500.hover--text-green-400.transition-colors js-wiegleb@t-online.de

        //- Github
        section
            h2.text-lg.font-bold.text-zinc-300.mb-3
            .bg-zinc-800.rounded-xl.p-6.border.border-zinc-700
                p.text-zinc-400
                    | Github:&nbsp;
                    a(href="https://github.com/LeTammo/" target="_blank").text-green-500.hover--text-green-400.transition-colors @LeTammo