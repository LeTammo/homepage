---
import Layout from '../../layouts/Layout.astro';
import en from '../../../locales/en.json';
import de from '../../../locales/de.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
  ];
}

const { lang } = Astro.params;
const locales = { en, de };
const t = locales[lang] || en;
---
<Layout title={`${t.impressum.title} | mathia.xyz`} activePage="impressum" lang={lang}>
    <div class="mb-10">
        <h1 class="text-3xl md:text-4xl font-bold text-zinc-200 mb-4">{t.impressum.title}</h1>
        <div class="h-1 w-16 bg-green-500 rounded"></div>
    </div>

    <div class="max-w-2xl space-y-5">
        <!-- My information -->
        <section class="bg-zinc-900/60 border border-zinc-800 shadow-md shadow-zinc-800/50 rounded-xl p-6 animate-fade-up">
            <h2 class="flex items-center gap-2 text-sm font-semibold text-zinc-500 uppercase tracking-widest mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500 shrink-0">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                {t.impressum.ownerTitle}
            </h2>
            <div class="space-y-1">
                <p class="text-zinc-200 font-semibold">{t.impressum.name}</p>
                <p class="text-zinc-500">{t.impressum.addressLine1}</p>
                <p class="text-zinc-500">{t.impressum.addressLine2}</p>
                <p class="text-zinc-500">{t.impressum.addressLine3}</p>
            </div>
        </section>

        <!-- Contact -->
        <section class="bg-zinc-900/60 border border-zinc-800 shadow-md shadow-zinc-800/50 rounded-xl p-6 animate-fade-up" style="animation-delay: 90ms">
            <h2 class="flex items-center gap-2 text-sm font-semibold text-zinc-500 uppercase tracking-widest mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500 shrink-0">
                    <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
                {t.impressum.contactTitle}
            </h2>
            <div class="flex flex-col gap-2">
                <a href="mailto:fe-wiegleb@t-online.de" class="text-zinc-400 hover:text-green-400 transition-colors w-fit">fe-wiegleb@t-online.de</a>
            </div>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Github -->
            <section class="bg-zinc-900/60 border border-zinc-800 shadow-md shadow-zinc-800/50 rounded-xl p-6 animate-fade-up" style="animation-delay: 180ms">
                <h2 class="flex items-center gap-2 text-sm font-semibold text-zinc-500 uppercase tracking-widest mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500 shrink-0">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                        <path d="M9 18c-4.51 2-5-2-7-2"></path>
                    </svg>
                    {t.impressum.Github}
                </h2>
                <a href="https://github.com/LeTammo/" target="_blank" class="text-zinc-400 hover:text-green-400 transition-colors w-fit">@LeTammo</a>
            </section>

            <!-- LinkedIn -->
            <section class="bg-zinc-900/60 border border-zinc-800 shadow-md shadow-zinc-800/50 rounded-xl p-6 animate-fade-up" style="animation-delay: 180ms">
                <h2 class="flex items-center gap-2 text-sm font-semibold text-zinc-500 uppercase tracking-widest mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500 shrink-0">
                        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                        <rect width="4" height="12" x="2" y="9"></rect>
                        <circle cx="4" cy="4" r="2"></circle>
                    </svg>
                    {t.impressum.LinkedIn}
                </h2>
                <a href="https://www.linkedin.com/in/jwiegleb" target="_blank" class="text-zinc-400 hover:text-green-400 transition-colors w-fit">@jwiegleb</a>
            </section>
        </div>

        <a href={`/${lang}`} class="inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-green-400 transition-colors pt-2 animate-fade-up" style="animation-delay: 270ms">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            {t.impressum.backHome}
        </a>
    </div>
</Layout>
