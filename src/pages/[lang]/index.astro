---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/home/Hero.astro';
import SkillsExperience from '../../components/home/SkillsExperience.astro';
import en from '../../../locales/en.json';
import de from '../../../locales/de.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
  ];
}

const { lang } = Astro.params;
const locales = { en, de };
const t = locales[lang] || en;
---
<Layout title={`${t.about.title} | mathia.xyz`} activePage="home" lang={lang}>
    <div>
        <Hero lang={lang} t={t} />
    </div>
    <div class="mt-16 pt-16 border-t border-zinc-800">
        <SkillsExperience lang={lang} t={t} />
    </div>
</Layout>
