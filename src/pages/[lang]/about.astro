---
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
  ];
}

const { lang } = Astro.params;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <title>mathia.xyz</title>
    <meta http-equiv="refresh" content={`0;url=/${lang}/`} />
    <script is:inline define:vars={{ lang }}>
      window.location.replace('/' + lang + '/');
    </script>
  </head>
  <body style="background: #09090b; color: #a1a1aa; font-family: sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0;">
    <p>Redirecting / Weiterleitung...</p>
  </body>
</html>
