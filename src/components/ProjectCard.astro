---
const { title, icon, image, tags, description, github, demo, delay = 0 } = Astro.props;
const primary = demo || github;
---
<!-- "isolate" scopes the -z-10 screenshot between the card background and its content -->
<div class="relative isolate overflow-hidden group p-5 border border-zinc-800 bg-zinc-900/60 hover:bg-zinc-800/50 hover:border-green-500/30 rounded-md transition-all duration-300 animate-fade-up flex flex-col" style={`animation-delay: ${delay}ms`}>
    <!-- Stretched primary link: covers the whole card, secondary links sit above it -->
    <a href={primary} target="_blank" class="absolute inset-0" aria-label={title}></a>

    <div class="absolute inset-x-0 top-0 h-28 -z-9 bg-linear-to-r to-zinc-900 mr-[24%]"></div>
    <div class="absolute inset-x-0 top-0 h-28 -z-8 bg-linear-to-b to-zinc-900"></div>
    <div class="absolute inset-x-0 top-0 h-28 -z-7 bg-zinc-900 ml-[76%]"></div>

    {image && (
        <div class="absolute inset-x-0 top-0 h-28 -z-10 pointer-events-none select-none duration-300 mask-[linear-gradient(to_bottom,black,transparent)]">
            <img src={image} alt="" class="w-full h-full object-cover object-top" />
        </div>
    )}

    <div class="flex items-start justify-between mb-4">
        {icon && (
            <div class="w-10 h-10 rounded-lg flex items-center justify-center">
                <img src={icon} alt="" class="w-full h-full object-cover object-top rounded-lg bg-zinc-850 shadow-md shadow-zinc-850" />
            </div>
        )}
        <div class="relative z-10 flex gap-1">
            {github && (
                <a href={github} target="_blank" title="GitHub" class="p-2 rounded-lg text-zinc-500 bg-zinc-900 hover:bg-zinc-800 transition-colors shadow-md shadow-zinc-500/50 border border-zinc-500/20 hover:shadow-green-500 hover:text-green-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                        <path d="M9 18c-4.51 2-5-2-7-2"></path>
                    </svg>
                </a>
            )}
            {demo && (
                <a href={demo} target="_blank" title="Live Demo" class="p-2 rounded-lg text-zinc-500 bg-zinc-900 hover:bg-zinc-800 transition-colors shadow-md shadow-zinc-500/50 border border-zinc-500/20 hover:shadow-green-500 hover:text-green-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                        <polyline points="15 3 21 3 21 9"></polyline>
                        <line x1="10" x2="21" y1="14" y2="3"></line>
                    </svg>
                </a>
            )}
        </div>
    </div>

    <div class="flex items-center gap-2">
        <h3 class="text-base font-semibold text-zinc-200 group-hover:text-green-400 transition-colors">{title}</h3>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-400 opacity-0 -translate-x-1 group-hover:opacity-90 group-hover:translate-x-0 transition-all duration-200">
            <path d="M5 12h14m0 0l-6-6m6 6l-6 6"></path>
        </svg>
    </div>

    <p class="text-sm text-zinc-500 leading-relaxed mt-2 grow">{description}</p>

    <p class="text-sm text-green-400/50 mt-4">{tags.join(' · ')}</p>
</div>
