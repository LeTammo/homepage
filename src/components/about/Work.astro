---
const { t } = Astro.props;
---
<h3 class="text-lg font-bold text-zinc-300 mb-6 flex items-center">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 text-green-600">
        <rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect>
        <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
    </svg>
    {t.about.work}
</h3>

<div class="space-y-6 relative pl-4 border-l border-zinc-800">
    <div class="relative">
        <div class="absolute -left-5.5 top-[4.5px] w-3 h-3 bg-green-600 rounded-full border-2 border-zinc-900 mt-1"></div>
        <div class="space-y-1">
            <span class="text-sm text-green-600 font-semibold uppercase tracking-wider">{t.about.workPresent} 06.2025</span>
            <h4 class="font-bold text-md text-zinc-400">{t.about.workPHP_Ilias}</h4>
            <p class="text-sm text-zinc-400">Databay AG</p>
            <ul class="text-sm text-zinc-500 list-disc pl-4 space-y-1 pt-1">
                <li>{t.about.workPHP_Ilias_1}</li>
                <li>{t.about.workPHP_Ilias_2}</li>
                <li>{t.about.workPHP_Ilias_3}</li>
            </ul>
        </div>
    </div>

    <div class="relative">
        <div class="absolute -left-5.5 top-[4.5px] w-3 h-3 bg-zinc-650 rounded-full border-2 border-zinc-900 mt-1"></div>
        <div class="space-y-1">
            <span class="text-sm text-zinc-500 font-semibold uppercase tracking-wider">01.2024 – 05.2025</span>
            <h4 class="font-bold text-md text-zinc-400">{t.about.workPHP_Seminar}</h4>
            <p class="text-sm text-zinc-400">Databay AG</p>
            <ul class="text-sm text-zinc-500 list-disc pl-4 space-y-1 pt-1">
                <li>{t.about.workPHP_Seminar_1}</li>
                <li>{t.about.workPHP_Seminar_2}</li>
                <li>{t.about.workPHP_Seminar_3}</li>
                <li>{t.about.workPHP_Seminar_4}</li>
                <li>{t.about.workPHP_Seminar_5}</li>
            </ul>
        </div>
    </div>

    <div class="relative">
        <div class="absolute -left-5.5 top-[4.5px] w-3 h-3 bg-zinc-650 rounded-full border-2 border-zinc-900 mt-1"></div>
        <div class="space-y-1">
            <span class="text-sm text-zinc-500 font-semibold uppercase tracking-wider">09.2020 – 12.2023</span>
            <h4 class="font-bold text-md text-zinc-400">{t.about.workMATSE}</h4>
            <p class="text-sm text-zinc-400">Databay AG</p>
            <ul class="text-sm text-zinc-500 list-disc pl-4 space-y-1 pt-1">
                <li>{t.about.workMATSE_1}</li>
                <li>{t.about.workMATSE_2}</li>
            </ul>
        </div>
    </div>

    <div class="relative">
        <div class="absolute -left-5.5 top-[4.5px] w-3 h-3 bg-zinc-650 rounded-full border-2 border-zinc-900 mt-1"></div>
        <div class="space-y-1">
            <span class="text-sm text-zinc-500 font-semibold uppercase tracking-wider">11.2016 – 09.2017</span>
            <h4 class="font-bold text-md text-zinc-400">{t.about.workSHK}</h4>
            <p class="text-sm text-zinc-400">HTWK Leipzig</p>
            <ul class="text-sm text-zinc-500 list-disc pl-4 space-y-1 pt-1">
                <li>{t.about.workSHK_1}</li>
                <li>{t.about.workSHK_2}</li>
            </ul>
        </div>
    </div>

    <div class="relative">
        <div class="absolute -left-5.5 top-[4.5px] w-3 h-3 bg-zinc-650 rounded-full border-2 border-zinc-900 mt-1"></div>
        <div class="space-y-1">
            <span class="text-sm text-zinc-500 font-semibold uppercase tracking-wider">12.2018 – 07.2020</span>
            <h4 class="font-bold text-md text-zinc-400">{t.about.workEzgs}</h4>
            <p class="text-sm text-zinc-400">Erich-Zeigner-Grundschule Leipzig</p>
            <ul class="text-sm text-zinc-500 list-disc pl-4 space-y-1 pt-1">
                <li>{t.about.workEzgs_1}</li>
            </ul>
        </div>
    </div>
</div>
