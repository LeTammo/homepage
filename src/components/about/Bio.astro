---
const { t } = Astro.props;
---
<div class="flex items-center space-x-8 xl:space-x-16">
    <div class="flex flex-col items-center gap-3">
        <div class="relative w-40 h-40 md:w-48 md:h-48 rounded-2xl border border-zinc-800 overflow-hidden" transition:name="profile-image">
            <img src="/images/me.jpg" alt="Profile" class="w-full h-full object-cover" />
        </div>

        <div class="space-y-1 w-full">
            <h2 class="text-xl font-bold text-zinc-400">Felix Jonas Wiegleb</h2>
            <p class="hidden text-xs text-green-500 font-medium">{t.about.subtitle}</p>
        </div>
    </div>

    <div class="flex flex-col items-center gap-6">
        <!-- Soft Skills section -->
        <div class="space-y-2">
            <h3 class="text-md font-bold uppercase tracking-wider pl-6 text-zinc-300">{t.about.softSkillsTitle}</h3>
            <ul class="text-sm space-y-2 text-zinc-400">
                <li class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-green-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span class="text-left">{t.about.soft1}</span>
                </li>
                <li class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-green-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span class="text-left">{t.about.soft2}</span>
                </li>
                <li class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-green-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span class="text-left">{t.about.soft3}</span>
                </li>
                <li class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-green-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span class="text-left">{t.about.soft4}</span>
                </li>
                <li class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-green-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span class="text-left">{t.about.soft5}</span>
                </li>
            </ul>
        </div>

        <div class="flex gap-3 w-full justify-center">
            <a href="https://github.com/LeTammo/" target="_blank" class="flex items-center justify-center p-2 rounded-lg bg-zinc-850 hover:bg-zinc-800 text-zinc-400 hover:text-white border border-zinc-800 transition-colors w-10 h-10" title="GitHub">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                    <path d="M9 18c-4.51 2-5-2-7-2"></path>
                </svg>
            </a>
            <a href="https://linkedin.com/in/jwiegleb/" target="_blank" class="flex items-center justify-center p-2 rounded-lg bg-zinc-850 hover:bg-zinc-800 text-zinc-400 hover:text-white border border-zinc-800 transition-colors w-10 h-10" title="LinkedIn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin">
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                    <rect width="4" height="12" x="2" y="9"></rect>
                    <circle cx="4" cy="4" r="2"></circle>
                </svg>
            </a>
            <a href="/files/Lebenslauf-CV-Wiegleb.pdf" download class="flex items-center justify-center gap-2 px-4 py-2.5 bg-green-600 hover:bg-green-500 text-white text-sm font-semibold rounded-lg transition-all duration-200 shadow-lg shadow-green-950/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" x2="12" y1="15" y2="3"></line>
                </svg>
                <span class="block lg:hidden xl:block">{t.about.downloadCV}</span>
                <span class="hidden lg:block xl:hidden">CV</span>
            </a>
            <p class="hidden text-xxs text-zinc-600 -mt-2">{t.about.cvNote}</p>
        </div>
    </div>
</div>