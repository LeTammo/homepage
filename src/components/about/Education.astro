---
const { t } = Astro.props;
---
<h3 class="text-lg font-bold text-zinc-300 mb-6 flex items-center">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 text-green-600">
        <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
        <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
    </svg>
    {t.about.education}
</h3>

<div class="space-y-6 relative pl-4 border-l border-zinc-800">
    <div class="relative">
        <div class="absolute -left-5.5 top-[4.5px] w-3 h-3 bg-green-600 rounded-full border-2 border-zinc-900 mt-1"></div>
        <div class="space-y-1">
            <span class="text-sm text-green-600 font-semibold uppercase tracking-wider">2020 – 2024</span>
            <h4 class="font-bold text-md text-zinc-400">{t.about.educationBachelor}</h4>
            <p class="text-sm text-zinc-400">FH Aachen</p>
            <ul class="hidden text-sm text-zinc-500 list-disc pl-4 space-y-1 pt-1">
                <li>{t.about.educationBachelor_1}</li>
            </ul>
        </div>
    </div>

    <div class="relative">
        <div class="absolute -left-5.5 top-[4.5px] w-3 h-3 bg-zinc-650 rounded-full border-2 border-zinc-900 mt-1"></div>
        <div class="space-y-1">
            <span class="text-sm text-zinc-500 font-semibold uppercase tracking-wider">2020 – 2023</span>
            <h4 class="font-bold text-md text-zinc-400">{t.about.educationMATSE}</h4>
            <p class="text-sm text-zinc-400">Databay AG</p>
        </div>
    </div>

    <div class="relative">
        <div class="absolute -left-5.5 top-[4.5px] w-3 h-3 bg-zinc-650 rounded-full border-2 border-zinc-900 mt-1"></div>
        <div class="space-y-1">
            <span class="text-sm text-zinc-500 font-semibold uppercase tracking-wider">2014 – 2020</span>
            <h4 class="font-bold text-md text-zinc-400">{t.about.educationHTWK}</h4>
            <p class="text-sm text-zinc-400">HTWK Leipzig ({t.about.noDegree})</p>
            <ul class="hidden text-sm text-zinc-500 list-disc pl-4 space-y-1 pt-1">
                <li>{t.about.educationHTWK_1}</li>
            </ul>
        </div>
    </div>

    <div class="relative">
        <div class="absolute -left-5.5 top-[4.5px] w-3 h-3 bg-zinc-650 rounded-full border-2 border-zinc-900 mt-1"></div>
        <div class="space-y-1">
            <span class="text-sm text-zinc-500 font-semibold uppercase tracking-wider">2012 – 2014</span>
            <h4 class="font-bold text-md text-zinc-400">{t.about.educationSchool}</h4>
            <p class="text-sm text-zinc-400">BSZ 7 Leipzig</p>
        </div>
    </div>
</div>
