---
const { activePage, lang, t } = Astro.props;
---
<div class="flex flex-col items-center xl:items-start w-full gap-6">
    <ul class="nav flex justify-center w-full gap-1 sm:gap-2 xl:gap-8">
        <li class="nav-item">
            <a href={`/${lang}`} class={`${activePage === 'home' ? 'text-green-500 bg-zinc-800/60' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/30'} nav-link text-base flex items-center px-2 py-1 sm:px-3 sm:py-2 rounded-md transition-all duration-200 w-full`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-home mr-1 sm:mr-2.5">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
                <span class="font-medium text-sm md:text-base">{t.nav.home}</span>
            </a>
        </li>

        <li class="nav-item">
            <a href={`/${lang}/about`} class={`${activePage === 'about' ? 'text-green-500 bg-zinc-800/60' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/30'} nav-link text-base flex items-center px-2 py-1 sm:px-3 sm:py-2 rounded-md transition-all duration-200 w-full`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-round mr-1 sm:mr-2.5">
                    <circle cx="12" cy="8" r="5"></circle>
                    <path d="M20 21a8 8 0 0 0-16 0"></path>
                </svg>
                <span class="font-medium text-sm md:text-base">{t.nav.about}</span>
            </a>
        </li>

        <li class="nav-item">
            <a href={`/${lang}/projects`} class={`${activePage === 'projects' ? 'text-green-500 bg-zinc-800/60' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/30'} nav-link text-base flex items-center px-2 py-1 sm:px-3 sm:py-2 rounded-md transition-all duration-200 w-full`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-rocket mr-1 sm:mr-2.5">
                    <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.3.09-3.1a2.18 2.18 0 0 0-3.11-.1z"></path>
                    <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path>
                    <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"></path>
                    <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path>
                </svg>
                <span class="font-medium text-sm md:text-base">{t.nav.projects}</span>
            </a>
        </li>

        <li class="nav-item">
            <a href="https://blog.mathia.xyz" target="_blank" class="text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/30 nav-link text-base flex items-center px-2 py-1 sm:px-3 sm:py-2 rounded-md transition-all duration-200 w-full">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-rss mr-1 sm:mr-2.5">
                    <path d="M4 11a9 9 0 0 1 9 9"></path>
                    <path d="M4 4a16 16 0 0 1 16 16"></path>
                    <circle cx="5" cy="19" r="1"></circle>
                </svg>
                <span class="font-medium text-sm md:text-base">{t.nav.blog}</span>
            </a>
        </li>
    </ul>
</div>
