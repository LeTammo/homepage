---
const { lang, t } = Astro.props;
const currentPath = Astro.url.pathname;

const getLangPath = (targetLang) => {
  const match = currentPath.match(/^\/(en|de)(\/.*)?$/);
  if (match) {
    const subpath = match[2] || '';
    return `/${targetLang}${subpath}`;
  }
  return `/${targetLang}${currentPath}`;
};

const currentYear = new Date().getFullYear();
---
<div class="bg-zinc-900 border-t border-zinc-800">
    <div class="container px-4 sm:px-6 py-3 mx-auto flex items-center justify-between gap-2">
        <!-- Left: copyright + impressum -->
        <div class="flex items-center gap-2 sm:gap-3 text-xs sm:text-sm text-zinc-500 min-w-0">
            <span class="shrink-0">© {currentYear}</span>
            <span class="text-zinc-700 hidden sm:inline">•</span>
            <a href={`/${lang}/impressum`} class="hover:text-zinc-300 transition-colors shrink-0">
                {t.footer.impressum}
            </a>
        </div>

        <!-- Center: p5.js animation controls — hidden on mobile -->
        <div class="footer-anim-group hidden sm:flex">
            <button class="footer-anim-btn" title="p5.js animation">✦ {t.footer.animation} ✦</button>
            <div class="footer-anim-popup">
                <a href="https://github.com/LeTammo/homepage/blob/main/public/js/sketch.js" target="_blank" class="footer-anim-btn">
                    🔗 p5.js
                </a>
                <span class="footer-anim-sep">•</span>
                <button class="footer-anim-btn" onclick="toggleColor()">✨ {t.footer.addColor}</button>
                <span class="footer-anim-sep">•</span>
                <button class="footer-anim-btn" onclick="toggleSpeed()">🔥 {t.footer.accelerate}</button>
            </div>
        </div>

        <!-- Right: language toggle -->
        <div class="flex items-center gap-1.5 sm:gap-2 text-xs sm:text-sm shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 hidden sm:block">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
                <path d="M2 12h20"></path>
            </svg>
            <a href={getLangPath('de')} class={`${lang === 'de' ? 'text-green-500 font-bold' : 'text-zinc-500 hover:text-zinc-300'} transition-colors focus:outline-none`}>DE</a>
            <span class="text-zinc-700 select-none">/</span>
            <a href={getLangPath('en')} class={`${lang === 'en' ? 'text-green-500 font-bold' : 'text-zinc-500 hover:text-zinc-300'} transition-colors focus:outline-none`}>EN</a>
        </div>
    </div>
</div>
